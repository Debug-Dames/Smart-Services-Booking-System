generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  userId Int
  name      String
  email     String   @unique
  password  String
  role      String   @default("customer") // customer | admin
  bookings  Booking[]
  createdAt DateTime @default(now())
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  duration    Int
  bookings    Booking[]
  createdAt   DateTime @default(now())
}

model Booking {
  id        Int      @id @default(autoincrement())
  date      DateTime
  status    String   @default("pending")
  userId    Int
  serviceId Int
  startTime DateTime
  endTime   DateTime
  user      User     @relation(fields: [userId], references: [id])
  service   Service  @relation(fields: [serviceId], references: [id])
  createdAt DateTime @default(now())
}